{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@runtime/*": ["runtime/*"]
    }
  },
  "include": ["runtime/**/*", "pages/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
